{
  "name": "expense-splitter-mcp",
  "version": "1.0.0",
  "description": "Expense Splitter MCP Server - Manage shared expenses with debt simplification",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "inspector": "npx @modelcontextprotocol/inspector npm run start",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "mcp",
    "expense-splitter",
    "model-context-protocol"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "mongoose": "^9.7.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.6.0",
    "prettier": "^3.9.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
